// ============================================
// AI Product Manager Agent Models
// ============================================

model GitHubActivity {
  id            String @id @default(cuid())
  workspaceId   String
  integrationId String

  // Event data
  eventType   String // "push", "pull_request", "pull_request_review"
  eventAction String? // "opened", "merged", "closed", "submitted", etc.
  externalId  String // GitHub delivery ID or commit SHA or PR node_id
  deliveryId  String? // x-github-delivery header for dedup

  // Commit data (for push events)
  commitSha     String?
  commitMessage String? @db.Text
  commitAuthor  String?
  commitUrl     String?
  branchName    String?

  // PR data (for pull_request events)
  prNumber      Int?
  prTitle       String?
  prState       String? // "open", "closed", "merged"
  prUrl         String?
  prAuthor      String?
  prMergedAt    DateTime?
  prReviewState String? // "approved", "changes_requested", "commented"
  prReviewer    String?

  // Repository
  repoFullName String
  repoUrl      String?

  // Mapping to internal entities
  actionId          String?
  mappingMethod     String? // "explicit", "branch", "semantic", "manual"
  mappingConfidence Float?

  // Timestamps
  eventTimestamp DateTime
  createdAt      DateTime @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  action      Action?     @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@unique([externalId, eventType])
  @@index([workspaceId])
  @@index([integrationId])
  @@index([actionId])
  @@index([eventTimestamp])
  @@index([repoFullName])
  @@index([branchName])
}

model SprintSnapshot {
  id           String   @id @default(cuid())
  listId       String
  snapshotDate DateTime @db.Date

  // Counts by kanban status
  backlogCount    Int @default(0)
  todoCount       Int @default(0)
  inProgressCount Int @default(0)
  inReviewCount   Int @default(0)
  doneCount       Int @default(0)
  cancelledCount  Int @default(0)

  // Effort tracking
  totalEffort     Float @default(0)
  completedEffort Float @default(0)
  addedEffort     Float @default(0) // Effort added after sprint start (scope creep)

  // Velocity
  actionsCompleted Int @default(0)

  // GitHub activity summary
  commitsCount Int @default(0)
  prsOpened    Int @default(0)
  prsMerged    Int @default(0)
  prsReviewed  Int @default(0)

  createdAt DateTime @default(now())

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, snapshotDate])
  @@index([listId])
  @@index([snapshotDate])
}

model SprintMetrics {
  id     String @id @default(cuid())
  listId String @unique

  // Velocity
  plannedEffort   Float @default(0)
  completedEffort Float @default(0)
  velocity        Float @default(0)

  // Throughput
  plannedActions   Int @default(0)
  completedActions Int @default(0)
  addedActions     Int @default(0)
  removedActions   Int @default(0)

  // Cycle times (averages in hours)
  avgCycleTime  Float? // Average time from TODO to DONE
  avgLeadTime   Float? // Average time from BACKLOG to DONE
  avgReviewTime Float? // Average time in IN_REVIEW

  // GitHub metrics
  totalCommits    Int    @default(0)
  totalPRs        Int    @default(0)
  avgPrTurnaround Float? // Average hours from PR open to merge

  // Completion
  completionRate Float?

  calculatedAt DateTime @default(now())

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model ActionStatusChange {
