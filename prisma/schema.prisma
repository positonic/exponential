  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  goals          Goal[]     @relation("GoalOutcomes")
  projects       Project[]  @relation("ProjectOutcomes")

  @@index([userId])
  @@index([projectId])
  @@index([workspaceId])
